{
  "name": "hookorama",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hookorama — local supervisor for LLM and CLI agents.",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd packages/web-app dev",
    "build": "tsdown && bun run --cwd packages/web-app build && bun run scripts/copy-web-app-to-cli.mjs",
    "typecheck": "tsdown && tsc -b --noEmit packages/client packages/supervisor packages/cli packages/extension packages/web-app && tsc -p e2e/tsconfig.json --noEmit",
    "lint": "oxlint . --ignore-pattern .worktrees",
    "test": "bun --bun vitest run --passWithNoTests --exclude .worktrees --exclude e2e",
    "test:e2e": "bunx --no-install playwright test --config e2e/playwright.config.ts",
    "test:e2e:build": "docker build -f e2e/Dockerfile -t hookorama-e2e .",
    "test:e2e:docker": "docker run --rm --init -p 3000:3000 hookorama-e2e",
    "test:e2e:ci": "docker run --rm --init -e CI=true hookorama-e2e",
    "check:md": "bun run scripts/check-md.ts",
    "check:files": "bun run scripts/check-files.ts",
    "check": "bun run check:md && bun run check:files",
    "demo:setup": "bun scripts/demo-setup.mjs",
    "demo": "bun run demo:setup",
    "ci": "bun run typecheck && bun run lint && bun run check && bun run test && bun run build",
    "memory:reindex": "bun run scripts/reindex-memory.ts"
  },
  "devDependencies": {
    "@hookorama/cli": "workspace:*",
    "@hookorama/client": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "tsdown": "^0.22.4",
    "tsx": "4.21.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
